# Margó Backend — Environment Variables
# Copy to .env and fill in your values.
# For local dev with docker-compose, only JWT_SECRET is required.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://margo:margo_dev@localhost:5432/margo
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# --- Auth (REQUIRED) ---
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=168
MAGIC_LINK_EXPIRY_MINUTES=15

# --- Anthropic (Sprint 3+) ---
# Required for AI menu extraction. Leave empty for demo mode with fake data.
ANTHROPIC_API_KEY=

# --- Cloudflare R2 (Sprint 4+) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=margo-invoices
R2_PUBLIC_URL=

# --- Email (Sprint 5+) ---
RESEND_API_KEY=

# --- Stripe (Sprint 8) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- App ---
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
