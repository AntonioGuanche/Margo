# Database (Railway provides this)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/margo

# Auth
JWT_SECRET=generate-a-random-64-char-string
MAGIC_LINK_EXPIRY_MINUTES=15

# Anthropic (for OCR + AI suggestions)
ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare R2 (S3-compatible storage for invoice images)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=margo-invoices
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Email (Resend)
RESEND_API_KEY=re_...
INBOUND_EMAIL_WEBHOOK_SECRET=

# Stripe (added in Sprint 8)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_MULTI=price_...

# App
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
